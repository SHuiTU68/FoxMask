<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="1080dp" android:height="2400dp"
    android:viewportWidth="1080" android:viewportHeight="2400">

    <!-- 背景：纵向渐变，深青到近黑（与品牌青 #00AF9C 呼应，让白狐面突出） -->
    <path android:pathData="M 0,0 H 1080 V 2400 H 0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear" android:startX="540" android:startY="0"
                android:endX="540" android:endY="2400">
                <item android:offset="0" android:color="#FF0C2A24"/>
                <item android:offset="0.5" android:color="#FF061A14"/>
                <item android:offset="1" android:color="#FF020A07"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- 狐面后方的柔光晕（大半透明圆，营造圣光感） -->
    <path android:fillColor="#1A00AF9C" android:pathData="M 540,1100 m -560,0 a 560,560 0 1,0 1120,0 a 560,560 0 1,0 -1120,0 Z"/>

    <!-- 底部远山剪影（双层，增加纵深） -->
    <path android:fillColor="#0A1F1A" android:pathData="M 0,2100 L 0,2400 L 1080,2400 L 1080,2100 C 900,1980 760,2020 540,2080 C 320,2020 180,1980 0,2100 Z"/>
    <path android:fillColor="#071510" android:pathData="M 0,2240 L 0,2400 L 1080,2400 L 1080,2240 C 820,2160 620,2200 540,2240 C 460,2200 260,2160 0,2240 Z"/>

    <!-- 居中大狐面：原 720x720 狐面以 scale 1.55 放大，中心置于 (540, 1050) -->
    <!-- 数学：pivot=(360,360) s=1.55 → translate = (540-360*1.55, 1050-360*1.55) = (-18, 492) -->
    <group android:scaleX="1.55" android:scaleY="1.55"
        android:pivotX="360" android:pivotY="360"
        android:translateX="-18" android:translateY="492">

        <!-- 狐面外发光（描边一圈柔和青光） -->
        <path android:strokeColor="#3300AF9C" android:strokeWidth="14" android:strokeLineJoin="round"
            android:pathData="M 360,108 L 296,72 L 248,162 C 192,184 148,260 148,348 C 148,444 200,540 292,602 L 360,638 L 428,602 C 520,540 572,444 572,348 C 572,260 528,184 472,162 L 424,72 Z"/>

        <!-- 主体面具（米白） -->
        <path android:fillColor="#F5F0E6" android:pathData="M 360,108 L 296,72 L 248,162 C 192,184 148,260 148,348 C 148,444 200,540 292,602 L 360,638 L 428,602 C 520,540 572,444 572,348 C 572,260 528,184 472,162 L 424,72 Z"/>

        <!-- 耳内侧（朱红） -->
        <path android:fillColor="#C8332B" android:pathData="M 296,72 L 266,150 L 286,150 L 300,108 Z"/>
        <path android:fillColor="#C8332B" android:pathData="M 424,72 L 454,150 L 434,150 L 420,108 Z"/>

        <!-- 额头中央菱纹 -->
        <path android:fillColor="#C8332B" android:pathData="M 360,150 L 344,182 L 360,206 L 376,182 Z"/>

        <!-- 眼周红纹 -->
        <path android:fillColor="#C8332B" android:pathData="M 244,332 C 270,306 316,320 326,358 C 304,386 252,374 244,332 Z"/>
        <path android:fillColor="#C8332B" android:pathData="M 476,332 C 450,306 404,320 394,358 C 416,386 468,374 476,332 Z"/>

        <!-- 眼睛（黑） -->
        <path android:fillColor="#1A1A1A" android:pathData="M 258,348 C 284,336 314,344 320,360 C 294,370 268,364 258,348 Z"/>
        <path android:fillColor="#1A1A1A" android:pathData="M 462,348 C 436,336 406,344 400,360 C 426,370 452,364 462,348 Z"/>

        <!-- 鼻子 -->
        <path android:fillColor="#1A1A1A" android:pathData="M 360,452 L 346,434 L 374,434 Z"/>

        <!-- 嘴部红纹 -->
        <path android:strokeColor="#C8332B" android:strokeWidth="6" android:strokeLineCap="round" android:pathData="M 360,452 L 360,488"/>
        <path android:strokeColor="#C8332B" android:strokeWidth="6" android:strokeLineCap="round" android:pathData="M 360,488 Q 344,504 330,498"/>
        <path android:strokeColor="#C8332B" android:strokeWidth="6" android:strokeLineCap="round" android:pathData="M 360,488 Q 376,504 390,498"/>

        <!-- 颊侧腮红 -->
        <path android:fillColor="#C8332B" android:pathData="M 196,408 C 214,400 232,404 242,416 C 226,428 204,422 196,408 Z"/>
        <path android:fillColor="#C8332B" android:pathData="M 524,408 C 506,400 488,404 478,416 C 494,428 516,422 524,408 Z"/>
    </group>

    <!-- 左上角小型狐面装饰（半透明，呼应主图） -->
    <group android:scaleX="0.22" android:scaleY="0.22"
        android:pivotX="360" android:pivotY="360"
        android:translateX="20" android:translateY="40">
        <path android:fillColor="#1AF5F0E6" android:pathData="M 360,108 L 296,72 L 248,162 C 192,184 148,260 148,348 C 148,444 200,540 292,602 L 360,638 L 428,602 C 520,540 572,444 572,348 C 572,260 528,184 472,162 L 424,72 Z"/>
    </group>

    <!-- 右下角小型狐面装饰（半透明，呼应主图） -->
    <group android:scaleX="0.22" android:scaleY="0.22"
        android:pivotX="360" android:pivotY="360"
        android:translateX="780" android:translateY="1750">
        <path android:fillColor="#1AF5F0E6" android:pathData="M 360,108 L 296,72 L 248,162 C 192,184 148,260 148,348 C 148,444 200,540 292,602 L 360,638 L 428,602 C 520,540 572,444 572,348 C 572,260 528,184 472,162 L 424,72 Z"/>
    </group>

</vector>
