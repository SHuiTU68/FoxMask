<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 设置 Kitsune 壁纸功能需要 SET_WALLPAPER（普通权限，安装时自动授予） -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <!-- miuix-blur 库声明的 minSdk=33 高于本项目 minSdk=23。
         该库内部有 isRenderEffectSupported()(API 31+)/isRuntimeShaderSupported()(API 33+)
         运行时判断，低版本自动降级；本项目所有液态玻璃调用均在 SettingsScreen 用
         Build.VERSION.SDK_INT >= TIRAMISU 守卫，悬浮底栏本身不依赖模糊也能工作。
         移植自 KernelSU（其 AndroidManifest 同样 override 此库）。 -->
    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur" />

    <application android:localeConfig="@xml/locale_config">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.APPLICATION_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.surequest.SuRequestActivity"
            android:directBootAware="true"
            android:exported="false"
            android:taskAffinity=""
            tools:ignore="AppLinkUrlError">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>

</manifest>
